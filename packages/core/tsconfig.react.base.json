{
  "compilerOptions": {
    "target": "ES2020",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "pretty": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "node",
    //    "skipLibCheck": true,
   // "typeRoots": ["definitions", "node_modules/@types"]
  },
  "exclude": [
    "**/node_modules",
    "**/build",
    "**/dist"
  ]
}